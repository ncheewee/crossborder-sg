# Frontend API base for local/dev builds.
# Use the deployed Cloudflare Worker URL once available, for example:
# NEXT_PUBLIC_API_BASE=https://crossborder-sg-api.your-subdomain.workers.dev
NEXT_PUBLIC_API_BASE=

# Public Google OAuth Web client id used by the browser login gate.
# Create this in Google Cloud Console as a Web application client.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Cloudflare Worker secret. Do not commit the real value.
# Configure with:
# npx wrangler secret put DATABASE_URL --config wrangler.api.toml
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Cloudflare Worker vars for Google sign-in.
# GOOGLE_CLIENT_ID is public-ish but must match NEXT_PUBLIC_GOOGLE_CLIENT_ID.
# AUTH_REQUIRED=false keeps the Worker open while testing; set true to gate API use.
GOOGLE_CLIENT_ID=
AUTH_REQUIRED=false
# Optional comma-separated controls:
# ALLOWED_EMAILS=you@gmail.com
# ALLOWED_DOMAINS=yourdomain.com
